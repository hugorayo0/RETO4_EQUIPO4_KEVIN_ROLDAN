public class Emisiones {

    private int idEmision;
    private int idServidor;
    private String fecha;
    private double co2Kg;
    private double consumoAguaLitros;

    public Emisiones() {
    }

    public Emisiones(int idEmision, int idServidor, String fecha, double co2Kg, double consumoAguaLitros) {
        this.idEmision = idEmision;
        this.idServidor = idServidor;
        this.fecha = fecha;
        this.co2Kg = co2Kg;
        this.consumoAguaLitros = consumoAguaLitros;
    }

    public int getIdEmision() {
        return idEmision;
    }

    public void setIdEmision(int idEmision) {
        this.idEmision = idEmision;
    }

    public int getIdServidor() {
        return idServidor;
    }

    public void setIdServidor(int idServidor) {
        this.idServidor = idServidor;
    }

    public String getFecha() {
        return fecha;
    }

    public void setFecha(String fecha) {
        this.fecha = fecha;
    }

    public double getCo2Kg() {
        return co2Kg;
    }

    public void setCo2Kg(double co2Kg) {
        this.co2Kg = co2Kg;
    }

    public double getConsumoAguaLitros() {
        return consumoAguaLitros;
    }

    public void setConsumoAguaLitros(double consumoAguaLitros) {
        this.consumoAguaLitros = consumoAguaLitros;
    }
}